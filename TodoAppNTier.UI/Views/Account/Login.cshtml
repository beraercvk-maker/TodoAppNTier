@model TodoAppNTier.Dtos.AppUserDtos.UserLoginDto
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header bg-success text-white text-center py-4">
                    <h3 class="font-weight-light my-2"><i class="bi bi-box-arrow-in-right"></i> Giriş Yap</h3>
                </div>
                <div class="card-body p-5">
                    
                    @* Şifre veya kullanıcı adı yanlışsa kırmızı hata burada çıkar *@
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                    <form asp-action="Login" asp-controller="Account" method="post">
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Username" class="form-control" placeholder="Kullanıcı Adı" required />
                            <label asp-for="Username">Kullanıcı Adı</label>
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Password" type="password" class="form-control" placeholder="Şifre" required />
                            <label asp-for="Password">Şifre</label>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                            <label asp-for="RememberMe" class="form-check-label">Beni Hatırla</label>
                        </div>

                        <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                            <a asp-action="Register" asp-controller="Account" class="small text-decoration-none">Hesabın yok mu? Kayıt Ol</a>
                            <button type="submit" class="btn btn-success px-4">Giriş Yap</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>