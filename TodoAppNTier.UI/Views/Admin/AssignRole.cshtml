@model List<TodoAppNTier.UI.Models.RoleAssignViewModel>
@{
    ViewData["Title"] = "Rol Atama";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-dark text-white p-4">
                    <h4 class="mb-0"><i class="bi bi-person-gear me-2"></i> Rol Atama: @ViewBag.UserName</h4>
                </div>
                <div class="card-body p-4">
                    
                    <form method="post" asp-action="AssignRole">
                        <input type="hidden" name="userId" value="@ViewBag.UserId" />

                        <div class="list-group mb-4">
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <label class="list-group-item d-flex gap-3 bg-light transition-hover py-3 cursor-pointer">
                                    <input type="hidden" asp-for="@Model[i].RoleId" />
                                    <input type="hidden" asp-for="@Model[i].RoleName" />
                                    
                                    <input class="form-check-input flex-shrink-0 fs-4 border-secondary" type="checkbox" asp-for="@Model[i].HasRole" />
                                    <span class="pt-1 form-checked-content">
                                        <strong class="d-block fs-5 text-dark">@Model[i].RoleName</strong>
                                        <span class="text-muted small">Bu rol kullanıcının sistemdeki erişim yetkilerini belirler.</span>
                                    </span>
                                </label>
                            }
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="UserList" class="btn btn-outline-secondary rounded-pill px-4">Vazgeç</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm"><i class="bi bi-save me-2"></i> Yetkileri Kaydet</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .transition-hover:hover { background-color: #e9ecef !important; transition: 0.2s ease; }
</style>