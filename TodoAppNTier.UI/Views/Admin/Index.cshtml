@{
    ViewData["Title"] = "Admin Kontrol Merkezi";
    Layout = "_Layout";
}

<div class="container mt-5">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger fw-bold"><i class="bi bi-speedometer2 me-2"></i> Kontrol Merkezi</h2>
        <span class="text-muted"><i class="bi bi-clock me-1"></i> Sistem Saati: @DateTime.Now.ToString("HH:mm")</span>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card bg-primary text-white border-0 shadow rounded-4 p-4 h-100">
                <h5 class="opacity-75"><i class="bi bi-people-fill me-2"></i>Toplam Kullanıcı</h5>
                <h2 class="display-4 fw-bold mb-0">@ViewBag.TotalUsers</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-dark text-white border-0 shadow rounded-4 p-4 h-100">
                <h5 class="text-warning"><i class="bi bi-list-task me-2"></i>Toplam Görev</h5>
                <h2 class="display-4 fw-bold mb-0">@ViewBag.TotalWorks</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white border-0 shadow rounded-4 p-4 h-100">
                <h5 class="opacity-75"><i class="bi bi-check-circle me-2"></i>Tamamlanan</h5>
                <h2 class="display-4 fw-bold mb-0">@ViewBag.CompletedWorks</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark border-0 shadow rounded-4 p-4 h-100">
                <h5 class="opacity-75"><i class="bi bi-hourglass-split me-2"></i>Bekleyen</h5>
                <h2 class="display-4 fw-bold mb-0">@ViewBag.PendingWorks</h2>
            </div>
        </div>
    </div>

    <h4 class="mb-3 fw-bold text-secondary">Hızlı Yönetim İşlemleri</h4>
    <div class="row g-4">
        <div class="col-md-6">
            <a asp-action="UserList" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 transition-hover p-4 text-center h-100">
                    <i class="bi bi-person-lines-fill text-danger display-4 mb-3"></i>
                    <h4 class="text-dark fw-bold">Kullanıcı Yönetimi</h4>
                    <p class="text-muted mb-0">Üyeleri listele, admin yetkisi ver veya sistemden banla.</p>
                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a asp-action="AllWorks" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 transition-hover p-4 text-center h-100">
                    <i class="bi bi-ui-checks-grid text-warning display-4 mb-3"></i>
                    <h4 class="text-dark fw-bold">Sistemdeki Tüm Görevler</h4>
                    <p class="text-muted mb-0">Tüm kullanıcıların eklediği görevleri ara, filtrele ve denetle.</p>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        transition: all 0.3s ease;
    }
</style>