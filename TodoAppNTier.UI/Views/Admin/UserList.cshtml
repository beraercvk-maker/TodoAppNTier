@model List<TodoAppNTier.Entities.Concrete.AppUser>
@{
    ViewData["Title"] = "Admin Paneli";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-danger bg-gradient text-white p-4 d-flex justify-content-between align-items-center">
            <h3 class="mb-0 fw-bold"><i class="bi bi-shield-lock me-2"></i> Sistem Kullanıcıları</h3>
            <span class="badge bg-white text-danger fs-6 rounded-pill px-3 py-2">Toplam: @Model.Count</span>
        </div>
        
        <div class="mb-4 text-end px-4 pt-4">
            <a asp-action="AllWorks" class="btn btn-warning rounded-pill px-4 shadow-sm fw-bold">
                <i class="bi bi-list-task"></i> Sistemdeki Tüm Görevleri Gör
            </a>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3">Ad Soyad</th>
                        <th>Kullanıcı Adı</th>
                        <th>Email</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.Count == 0)
                    {
                        <tr><td colspan="4" class="text-center py-5 text-muted">Sistemde henüz başka kullanıcı yok.</td></tr>
                    }
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">@user.Name @user.Surname</td>
                            <td class="text-muted">@@@user.UserName</td>
                            <td>@user.Email</td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-pill">
                                    <a asp-action="AssignRole" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary px-3 py-2" title="Rol Ata">
    <i class="bi bi-person-gear"></i> Rol Ata
</a>
                                    <a asp-action="BanUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning px-3 py-2" title="Süresiz Banla">
                                        <i class="bi bi-slash-circle"></i>
                                    </a>
                                    <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger px-3 py-2" onclick="return confirm('Bu kullanıcı tamamen silinecek. Emin misin?')" title="Hesabı Sil">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>