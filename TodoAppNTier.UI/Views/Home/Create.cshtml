@model TodoAppNTier.Dtos.WorkDtos.WorkCreateDto

<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <title>Todo App - Yeni Görev Ekle</title> 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light"> 
   
    <div class="container my-5">
        <div class="row">
            <div class="col-md-6 offset-md-3">
                
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h4 class="card-title text-center text-primary mb-3">Yeni Görev Ekle</h4>
                        
                        <form asp-action="Create" asp-controller="Home" method="post">
                            <div class="mb-3">
                                <label asp-for="Definition" class="form-label">Görev Tanımı: </label>
                                <input asp-for="Definition" class="form-control" />
                                <span asp-validation-for="Definition" class="text-danger"></span>
                            </div>
                          
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" asp-for="IsCompleted">
                                <label class="form-check-label" asp-for="IsCompleted">
                                    Tamamlandı olarak işaretle
                                </label>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary">Görevi Kaydet</button>
                            </div>

                             <div class="text-center mt-3">
                                <a asp-action="Index" class="btn btn-link">Listeye Geri Dön</a>
                            </div>

                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>
