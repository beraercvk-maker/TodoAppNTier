@{
    ViewData["Title"] = "Sayfa Bulunamadı";
}

<div class="container text-center" style="margin-top: 100px;">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="display-1 fw-bold text-danger">404</h1>
            <h2 class="mb-4">Oops! Aradığınız sayfayı bulamadık.</h2>
            <p class="lead text-muted mb-5">
                Girmeye çalıştığınız görev (ID) silinmiş olabilir, URL'yi yanlış yazmış olabilirsiniz veya böyle bir sayfa hiç var olmamış olabilir.
            </p>
            
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-warning mb-4">
                    <strong>Bilgi:</strong> @TempData["ErrorMessage"]
                </div>
            }

            <a asp-action="Index" asp-controller="Home" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-house-door"></i> Anasayfaya Güvenle Dön
            </a>
        </div>
    </div>
</div>